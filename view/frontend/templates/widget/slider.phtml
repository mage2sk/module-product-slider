<?php
/**
 * Panth ProductSlider Widget Template
 *
 * Uses Hyva's native snap-slider and ProductListItem renderer for consistent look.
 * Identical to Hyva's product-slider.phtml with added autoplay and badge support.
 *
 * @var $block \Panth\ProductSlider\Block\Widget\ProductSlider
 * @var $escaper \Magento\Framework\Escaper
 */

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\LucideIcons;
use Hyva\Theme\ViewModel\ProductListItem;
use Magento\Catalog\Block\Product\ReviewRendererInterface as ProductReviewRenderer;
use Magento\Framework\View\Element\Template;

/** @var ViewModelRegistry $viewModels */
$lucideIcons = $viewModels->require(LucideIcons::class);

/** @var ProductListItem $productListItemViewModel */
$productListItemViewModel = $viewModels->require(ProductListItem::class);

$config = $block->getSliderConfig();
$products = $block->getProductCollection();
$sliderId = $block->getSliderId();
$trackClasses = $block->getColumnTrackClasses();

if (!$products || $products->getSize() == 0) {
    return '';
}

$columnCount = (int) ($config['columns_desktop'] ?? 4);
$showPager = $config['show_pager'] ?? true;
$showHeading = ($config['show_heading'] ?? true) && !empty($config['title']);

$itemRenderer = $block->getLayout()->getBlock('product_list_item')
    ?: $block->getChildBlock('slider.item.template')
    ?: $block->getLayout()->createBlock(Template::class);
?>

<section
    id="<?= $escaper->escapeHtmlAttr($sliderId) ?>"
    class="snap-slider product-slider my-8"
    aria-label="<?= $escaper->escapeHtmlAttr($config['title'] ?? __('Product Slider')) ?>"
    x-data
    <?php if (!empty($config['enable_autoplay'])): ?>
    x-init="
        let interval;
        const startAutoplay = () => {
            interval = setInterval(() => {
                const nextBtn = $el.querySelector('[data-next]');
                if (nextBtn && !nextBtn.disabled) {
                    nextBtn.click();
                } else {
                    const first = $el.querySelector('[data-track] > *:first-child');
                    if (first) first.scrollIntoView({ block: 'nearest', inline: 'start' });
                }
            }, <?= (int)($config['autoplay_interval'] ?? 5000) ?>);
        };
        startAutoplay();
        $el.addEventListener('mouseenter', () => clearInterval(interval));
        $el.addEventListener('mouseleave', startAutoplay);
    "
    <?php endif; ?>
    x-snap-slider.group-pager
    x-defer="intersect"
>
    <a
        href="#<?= $escaper->escapeHtmlAttr($sliderId) ?>-slider-end"
        class="sr-only focus:not-sr-only focus:absolute focus:z-30 focus:bg-white"
    ><?= $escaper->escapeHtml(__('Press to skip carousel')) ?></a>

    <div class="flex gap-2 justify-between items-start">
        <div class="flex-1 min-w-0">
            <?php if ($showHeading): ?>
                <?= /** @noEscape */ sprintf(
                    '<%1$s class="text-2xl font-medium">%2$s</%1$s>',
                    $escaper->escapeHtml($config['heading_tag'] ?? 'h3'),
                    $escaper->escapeHtml($config['title'])
                ) ?>
            <?php endif; ?>
            <?php if (!empty($config['description'])): ?>
                <div class="text-sm text-gray-500 mt-1"><?= /** @noEscape */ $config['description'] ?></div>
            <?php endif; ?>
        </div>
        <div class="flex gap-2 shrink-0">
            <button
                class="btn btn-secondary p-2 invisible"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Previous Slide')) ?>"
                data-prev
                disabled
            ><?= $lucideIcons->arrowLeftHtml('rtl:-rotate-180', 18, 18, ['aria-hidden' => 'true']); ?></button>
            <button
                class="btn btn-secondary p-2 invisible"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Next Slide')) ?>"
                data-next
                disabled
            ><?= $lucideIcons->arrowRightHtml('rtl:-rotate-180', 18, 18, ['aria-hidden' => 'true']); ?></button>
        </div>
    </div>

    <div class="<?= /* @noEscape */ $trackClasses ?> p-1 -m-1" data-track tabindex="0" aria-live="polite">
        <?php foreach ($products as $product): ?>
            <div
                id="<?= $escaper->escapeHtmlAttr($sliderId . '-' . $product->getId()) ?>"
                class="flex flex-col"
                role="tabpanel"
            >
                <?= /** @noEscape */ $productListItemViewModel->getItemHtmlWithRenderer(
                    $itemRenderer,
                    $product,
                    $block,
                    'grid',
                    ProductReviewRenderer::SHORT_VIEW,
                    'category_page_grid',
                    false
                ) ?>
            </div>
        <?php endforeach; ?>
    </div>

    <?php if ($showPager): ?>
        <div class="snap-pager" data-pager>
            <?php foreach ($products as $product): ?>
                <a
                    href="#<?= $escaper->escapeHtmlAttr($sliderId . '-' . $product->getId()) ?>"
                    class="snap-marker"
                    role="tab"
                    x-cloak
                >
                    <span class="sr-only">
                        <?= $escaper->escapeHtml(__('View more about %1', $product->getName())) ?>
                    </span>
                </a>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>

    <span id="<?= $escaper->escapeHtmlAttr($sliderId) ?>-slider-end" tabindex="-1"></span>
</section>
<style>
#<?= $escaper->escapeHtmlAttr($sliderId) ?> .price-box { display: flex; flex-wrap: wrap; align-items: baseline; gap: 4px 8px; }
#<?= $escaper->escapeHtmlAttr($sliderId) ?> .old-price .price { text-decoration: line-through; color: #9CA3AF; font-size: 0.875rem; }
</style>
