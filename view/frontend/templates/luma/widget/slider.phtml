<?php
/**
 * Panth ProductSlider Widget — Luma Template
 * Uses Swiper.js (from Panth_Core) for carousel
 * Vanilla JS, no Alpine.js
 *
 * @var $block \Panth\ProductSlider\Block\Widget\ProductSlider
 * @var $escaper \Magento\Framework\Escaper
 */

$config = $block->getSliderConfig();
$products = $block->getProductCollection();
$sliderId = $block->getSliderId();

if (!$products || $products->getSize() == 0) {
    return '';
}

$columnDesktop = (int)($config['columns_desktop'] ?? 4);
$columnTablet = (int)($config['columns_tablet'] ?? 2);
$columnMobile = (int)($config['columns_mobile'] ?? 1);
$showPager = $config['show_pager'] ?? true;
$showHeading = ($config['show_heading'] ?? true) && !empty($config['title']);
$enableAutoplay = !empty($config['enable_autoplay']);
$autoplayInterval = (int)($config['autoplay_interval'] ?? 5000);
$headingTag = $escaper->escapeHtml($config['heading_tag'] ?? 'h3');
$title = $escaper->escapeHtml($config['title'] ?? __('Products'));
?>

<style>
.panth-product-slider { margin: 32px 0 48px; font-family: 'DM Sans', 'Inter', system-ui, sans-serif; position: relative; }
.panth-product-slider .slider-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.panth-product-slider .slider-title { font-size: 24px; font-weight: 700; color: #171717; margin: 0; }
.panth-product-slider .slider-nav { display: flex; gap: 8px; }
.panth-product-slider .slider-nav button { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #E5E7EB; background: #fff; color: #374151; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; padding: 0; }
.panth-product-slider .slider-nav button:hover { border-color: var(--color-primary, #0D9488); color: var(--color-primary, #0D9488); background: #F0FDFA; }
.panth-product-slider .slider-nav button.swiper-button-disabled { opacity: 0.3; cursor: default; }
.panth-product-slider .slider-nav button svg { width: 18px; height: 18px; }
.panth-product-slider .swiper { overflow: hidden; padding-bottom: 4px; }
.panth-product-slider .swiper-slide { height: auto; }
.panth-product-slider .product-card { border: 1px solid #E5E7EB; border-radius: 12px; overflow: hidden; background: #fff; height: 100%; display: flex; flex-direction: column; transition: box-shadow 0.2s; }
.panth-product-slider .product-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
.panth-product-slider .product-card-image { position: relative; padding-top: 100%; overflow: hidden; background: #F9FAFB; }
.panth-product-slider .product-card-image img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain; }
.panth-product-slider .product-card-image a { display: block; position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.panth-product-slider .product-card-body { padding: 12px 16px 16px; flex: 1; display: flex; flex-direction: column; }
.panth-product-slider .product-card-name { font-size: 14px; font-weight: 600; color: #171717; margin: 0 0 8px; line-height: 1.4; }
.panth-product-slider .product-card-name a { color: inherit; text-decoration: none; }
.panth-product-slider .product-card-name a:hover { color: var(--color-primary, #0D9488); }
.panth-product-slider .product-card-price { font-size: 16px; font-weight: 700; color: #171717; margin-top: auto; }
.panth-product-slider .product-card-price .old-price { font-size: 13px; color: #A3A3A3; text-decoration: line-through; margin-right: 6px; font-weight: 400; }
.panth-product-slider .product-card-price .special-price { color: #DC2626; }
.panth-product-slider .slider-pagination { margin-top: 20px; text-align: center; display: flex; justify-content: center; gap: 6px; }
.panth-product-slider .slider-pagination .swiper-pagination-bullet { width: 8px; height: 8px; background: #D1D5DB; opacity: 1; border-radius: 50%; display: inline-block; cursor: pointer; transition: all 0.2s; }
.panth-product-slider .slider-pagination .swiper-pagination-bullet-active { background: var(--color-primary, #0D9488); width: 24px; border-radius: 4px; }
@media (max-width: 767px) {
    .panth-product-slider .slider-title { font-size: 18px; }
    .panth-product-slider .slider-nav button { width: 32px; height: 32px; }
    .panth-product-slider .slider-nav button svg { width: 14px; height: 14px; }
}
</style>

<?php $description = $config['description'] ?? ''; ?>
<section class="panth-product-slider" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>">
    <div class="slider-header">
        <div style="flex:1;min-width:0;">
            <?php if ($showHeading): ?>
                <<?= /* @noEscape */ $headingTag ?> class="slider-title"><?= /* @noEscape */ $title ?></<?= /* @noEscape */ $headingTag ?>>
            <?php endif; ?>
            <?php if ($description): ?>
                <div style="font-size:14px;color:#6B7280;margin-top:4px;"><?= /** @noEscape */ $description ?></div>
            <?php endif; ?>
        </div>
        <div class="slider-nav" style="flex-shrink:0;">
            <button type="button" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>-prev" aria-label="<?= $escaper->escapeHtmlAttr(__('Previous')) ?>">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button type="button" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>-next" aria-label="<?= $escaper->escapeHtmlAttr(__('Next')) ?>">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
        </div>
    </div>

    <div class="swiper" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>-swiper">
        <div class="swiper-wrapper">
            <?php foreach ($products as $product): ?>
                <?php
                $productUrl = $product->getProductUrl();
                $productName = $escaper->escapeHtml($product->getName());
                $mediaUrl = $block->getProductImageUrl($product, 'category_page_grid', 300, 300);

                $price = $product->getFinalPrice();
                $regularPrice = $product->getPrice();
                $hasSpecialPrice = $price < $regularPrice;
                ?>
                <div class="swiper-slide">
                    <div class="product-card">
                        <div class="product-card-image">
                            <a href="<?= $escaper->escapeUrl($productUrl) ?>" title="<?= $escaper->escapeHtmlAttr($productName) ?>">
                                <img src="<?= $escaper->escapeUrl($mediaUrl) ?>"
                                     alt="<?= $escaper->escapeHtmlAttr($productName) ?>"
                                     loading="lazy"
                                     width="300" height="300" />
                            </a>
                        </div>
                        <div class="product-card-body">
                            <h4 class="product-card-name">
                                <a href="<?= $escaper->escapeUrl($productUrl) ?>"><?= /* @noEscape */ $productName ?></a>
                            </h4>
                            <div class="product-card-price">
                                <?php if ($hasSpecialPrice): ?>
                                    <span class="old-price"><?= $escaper->escapeHtml($block->formatPrice($regularPrice)) ?></span>
                                    <span class="special-price"><?= $escaper->escapeHtml($block->formatPrice($price)) ?></span>
                                <?php else: ?>
                                    <?= $escaper->escapeHtml($block->formatPrice($price)) ?>
                                <?php endif; ?>
                            </div>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>

    <?php if ($showPager): ?>
        <div class="slider-pagination" id="<?= $escaper->escapeHtmlAttr($sliderId) ?>-pagination"></div>
    <?php endif; ?>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';
    var sliderId = '<?= $escaper->escapeJs($sliderId) ?>';
    var swiperEl = document.getElementById(sliderId + '-swiper');
    if (!swiperEl || typeof Swiper === 'undefined') return;

    var swiper = new Swiper('#' + sliderId + '-swiper', {
        slidesPerView: <?= (int)$columnMobile ?>,
        spaceBetween: 16,
        loop: false,
        <?php if ($enableAutoplay): ?>
        autoplay: {
            delay: <?= (int)$autoplayInterval ?>,
            disableOnInteraction: false,
            pauseOnMouseEnter: true
        },
        <?php endif; ?>
        navigation: {
            nextEl: '#' + sliderId + '-next',
            prevEl: '#' + sliderId + '-prev'
        },
        <?php if ($showPager): ?>
        pagination: {
            el: '#' + sliderId + '-pagination',
            clickable: true
        },
        <?php endif; ?>
        breakpoints: {
            768: { slidesPerView: <?= (int)$columnTablet ?>, spaceBetween: 16 },
            1024: { slidesPerView: <?= (int)$columnDesktop ?>, spaceBetween: 20 }
        }
    });
});
</script>
